# Copie para .env e preencha com os valores reais (não commitar o .env de verdade).

# Mongo self-hosted no EasyPanel (migrado do Atlas em 2026-07-09, ver NOTES.md).
# Precisa rodar como replica set (Prisma exige transação até pra updates simples) —
# se faltar `replicaSet=rs0` ou o Mongo não tiver sido iniciado com `--replSet rs0`,
# operações de escrita falham com erro P2031.
DATABASE_URL="mongodb://USUARIO:SENHA@easypanel.quattoracademia.com:27017/quattor?tls=false&authSource=admin&replicaSet=rs0"

# EVO (integração) — header Authorization completo, ex.: "Basic XXXX..."
EVO_INTEGRACAO_API_KEY="Basic ..."

# Porta que o leitor facial usa pra se conectar (MENU > REDE > SERVIDOR > Porta na catraca).
CATRACA_WS_PORT=7792

# Opcional — intervalo do job de sincronização de status com a EVO (ms). Default 10 min.
# EVO_SYNC_INTERVAL_MS=600000

# idTurnstile do leitor facial cadastrado na EVO (GET /api/v2/accessControl/turnstiles) —
# usado pra confirmar check-in Wellhub/Totalpass quando o aluno está inativo localmente.
EVO_ID_TURNSTILE_FACIAL=8

# Wellhub (Gympass) Access Control API — validação de check-in direto com a Wellhub,
# sem depender da EVO. Token e X-Gym-Id obtidos com o Tech Sales da Wellhub
# (integrations@gympass.com) ou pelo Help Center ("solicitar token de integração").
# Sem essas duas variáveis, validarCheckInWellhub() é no-op (retorna null).
# WELLHUB_ACCESS_TOKEN=
# WELLHUB_GYM_ID=
# Sandbox pra testar antes de ter credenciais de produção:
# WELLHUB_BASE_URL=https://apitesting.partners.gympass.com
