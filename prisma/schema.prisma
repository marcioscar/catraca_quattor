generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

// Mesmo banco Mongo usado pelo app principal (recepcao) — só essas duas
// coleções pertencem à catraca; o resto do banco não é tocado daqui.
model CatracaAluno {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    idMember     Int       @unique // idMember (aluno) ou idEmployee (colaborador) da EVO, reusado como enrollid no device
    nome         String?
    tipo         String    @default("aluno") // "aluno" | "colaborador" — define contra qual API da EVO sincronizar o `ativo`
    wellhubId    String? // gympass_id do aluno na Wellhub, preenchido manualmente — usado pra validar check-in direto na API da Wellhub quando `ativo` é false
    fotoBase64   String? // vem do próprio device (senduser) ou capturada na recepção
    ativo        Boolean   @default(true) // sincronizado pelo job periódico de status EVO
    comDebito    Boolean   @default(false) // aluno com dívida vencida em aberto na EVO — sincronizado a cada ciclo (evo-debito-sync.ts), bloqueia acesso mesmo ativo
    idMembershipsAtivos Int[] @default([]) // idMembership dos contratos ativos (EVO) — sincronizado periodicamente, usado pra restrição de horário (ver horario-restricao.ts). Só relevante pra tipo "aluno".
    turmaHorarios Json? // cache dos horários de turma (weekDay/startTime/endTime) — só preenchido quando todos os planos ativos são do tipo "turma" (ver evo-turma-sync.ts)
    enroladoEm   DateTime  @default(now())
    atualizadoEm DateTime  @updatedAt
    removidoEm   DateTime?

    @@index([ativo])
}

// Cadastro completo puxado de GET /api/v2/members (EVO) — coleção separada
// da CatracaAluno (que é enxuta, só o necessário pra decisão de acesso).
// Populada por `scripts/sync-evo-clientes.ts` / `POST /catraca/sincronizar-clientes`.
model EvoCliente {
    id                          String    @id @default(auto()) @map("_id") @db.ObjectId
    idMember                    Int       @unique
    firstName                   String?
    lastName                    String?
    registerName                String?
    registerLastName            String?
    registerDate                DateTime?
    idBranch                    Int?
    branchName                  String?
    accessBlocked               Boolean?
    blockedReason               String?
    document                    String?
    documentId                  String?
    maritalStatus               String?
    gender                      String?
    birthDate                   DateTime?
    updateDateEvo               DateTime? // `updateDate` da EVO — nome diferente do nosso `atualizadoEm` (@updatedAt) pra não confundir
    address                     String?
    state                       String?
    city                        String?
    zipCode                     String?
    complement                  String?
    neighborhood                String?
    accessCardNumber            String?
    number                      String?
    totalFitCoins                Int?
    membershipStatus            String?
    penalized                   Boolean?
    status                      String?
    email                       String? // extraído de contacts[] (contactType == "E-mail")
    telefone                    String? // extraído de contacts[] (contactType == "Cellphone")
    lastAccessDate              DateTime?
    conversionDate              DateTime?
    idEmployeeConsultant         Int?
    nameEmployeeConsultant       String?
    idEmployeeInstructor         Int?
    nameEmployeeInstructor       String?
    idEmployeePersonalTrainer    Int?
    nameEmployeePersonalTrainer  String?
    photoUrl                    String?
    country                     String?
    idMemberMigration            String?
    gympassId                   String? // mesmo dado replicado em CatracaAluno.wellhubId, pra não acoplar a decisão de acesso a esta coleção
    personalTrainer             Boolean?
    personalType                String?
    cref                        String?
    crefExpirationDate          DateTime?
    codeTotalpass               String?
    userIdGurupass              String?
    clientWithPromotionalRestriction Boolean?
    raw                         Json? // payload bruto da EVO, pra campos que ainda não mapeamos explicitamente
    sincronizadoEm              DateTime  @default(now())
    atualizadoEm                DateTime  @updatedAt

    @@index([gympassId])
    @@index([document])
}

// Catálogo de planos da EVO (GET /api/v2/membership) — pensando na migração
// futura pra fora da EVO, guarda os planos localmente. NÃO inclui "Horários
// de contrato" (restrição de dia/hora por plano, ver painel admin da EVO) —
// esse dado não é exposto por esse endpoint nem achamos outro que exponha
// (só o motor interno `entryAuthorize` da EVO parece ter acesso, ver
// NOTES.md, blockedType 9).
model EvoPlano {
    id             String   @id @default(auto()) @map("_id") @db.ObjectId
    idMembership   Int      @unique
    idBranch       Int?
    nameMembership String?
    membershipType String?
    durationType   String?
    duration       Int?
    value          Float?
    description    String?
    inactive       Boolean?
    displayName    String?
    raw            Json? // payload bruto da EVO (entries, differentials, accessBranches, etc.)
    sincronizadoEm DateTime @default(now())
    atualizadoEm   DateTime @updatedAt
}

model CatracaAcessoLog {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    idMember   Int // == enrollid recebido no sendlog
    nome       String?
    permitido  Boolean
    motivo     String? // "ok" | "plano_inativo" | "nao_cadastrado" | "wellhub_provisorio" | "wellhub_ok"
    personType Int? // 1=Aluno, 3=Funcionário (EVO) — só setado quando permitido=true, pra sincronizar depois
    ocorridoEm DateTime @default(now())

    // Entrada ainda não registrada na EVO (bloqueado hoje por permissão — ver NOTES.md
    // "Próximos passos" item 3). Só relevante quando permitido=true. Quando o bloqueio for
    // resolvido, um job de sincronização retroativa processa quem estiver com isso em false.
    sincronizadoEvo Boolean @default(false)

    @@index([idMember])
    @@index([ocorridoEm])
    @@index([sincronizadoEvo])
}
